# GMX Dashboard Environment Variables
# Copy this file to .env.local and fill in values

# CoinGecko API Key (optional - for higher rate limits)
# Get one at: https://www.coingecko.com/en/api/pricing
COINGECKO_API_KEY=

# No API keys required for DeFiLlama (free, no auth)
# No API keys required for basic CoinGecko (free tier)
